---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: Date;
  noindex?: boolean;
}

const {
  title,
  description = "Exploring personal finance strategies and AI tools to build wealth smarter.",
  image = "/og-default.png",
  type = "website",
  publishedDate,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image.startsWith("http") ? image : new URL(image, Astro.site).toString();
const fullTitle = title === "Home" ? "WealthLab — Personal Finance & AI Tools" : `${title} | WealthLab`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="sitemap" href="/sitemap.xml" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="impact-site-verification" value="0f47efc4-f3e2-4fa2-b0cb-d93f8780e4ec" />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="WealthLab" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="WealthLab" />
    <meta property="og:locale" content="en_US" />
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <!-- <meta name="twitter:site" content="@yourhandle" /> -->

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": type === "article" ? "Article" : "WebSite",
      name: fullTitle,
      description,
      url: canonicalURL,
      ...(type === "article" && publishedDate && { datePublished: publishedDate.toISOString() }),
      publisher: {
        "@type": "Organization",
        name: "WealthLab",
        url: Astro.site,
      },
    })} />
  </head>
  <body class="bg-surface text-gray-900 font-sans min-h-screen flex flex-col">
    <header class="border-b border-gray-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-primary">WealthLab</a>
        <ul class="flex gap-6 text-sm font-medium">
          <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/resources" class="hover:text-primary transition-colors">Tools</a></li>
          <li><a href="/about" class="hover:text-primary transition-colors">About</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 max-w-4xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <footer class="border-t border-gray-200 bg-white">
      <div class="max-w-4xl mx-auto px-4 py-6 flex flex-col items-center gap-4 text-sm text-gray-500">
        <p class="text-xs text-gray-400 text-center max-w-2xl">
          The content on WealthLab is for informational and educational purposes only and does not
          constitute financial, investment, or legal advice. Always consult a qualified financial
          advisor before making investment decisions.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/affiliate-disclosure" class="hover:text-primary transition-colors">Affiliate Disclosure</a>
          <a href="/privacy-policy" class="hover:text-primary transition-colors">Privacy Policy</a>
          <a href="/terms" class="hover:text-primary transition-colors">Terms</a>
          <a href="/disclaimer" class="hover:text-primary transition-colors">Disclaimer</a>
          <a href="/contact" class="hover:text-primary transition-colors">Contact</a>
          <a href="/about" class="hover:text-primary transition-colors">About</a>
        </div>
        <span>&copy; {new Date().getFullYear()} WealthLab. All rights reserved.</span>
      </div>
    </footer>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import AffiliateLink from "../components/AffiliateLink.astro";

const categories = [
  {
    name: "AI Finance Tools",
    tools: [
      { name: "Copilot Money", url: "#", description: "AI-powered budgeting with beautiful dashboards and smart insights.", free: false },
      { name: "Monarch Money", url: "#", description: "Best for couples. Shared finances with AI-driven suggestions.", free: false },
      { name: "ChatGPT + Plugins", url: "#", description: "Use GPT for custom financial analysis, tax questions, and investment modeling.", free: true },
    ],
  },
  {
    name: "Investing Platforms",
    tools: [
      { name: "Betterment", url: "#", description: "Automated investing with tax-loss harvesting and goal-based portfolios.", free: false },
      { name: "Wealthfront", url: "#", description: "Robo-advisor with direct indexing and automated financial planning.", free: false },
      { name: "Fidelity", url: "#", description: "Zero-fee index funds and excellent research tools for self-directed investors.", free: true },
    ],
  },
  {
    name: "Productivity & AI",
    tools: [
      { name: "Notion AI", url: "#", description: "All-in-one workspace with AI writing, summaries, and database automation.", free: false },
      { name: "Perplexity", url: "#", description: "AI search engine — great for quick financial research with sources.", free: true },
      { name: "Claude", url: "#", description: "Advanced AI assistant for analysis, writing, and complex reasoning tasks.", free: true },
    ],
  },
];
---

<BaseLayout title="Resources & Tools" description="Curated tools and resources for personal finance and AI — everything we use and recommend.">
  <h1 class="text-3xl font-bold mb-2">Resources & Tools</h1>
  <p class="text-gray-600 mb-8">
    Our curated picks for personal finance and AI tools. We use or have tested everything listed here.
    Links marked with a dotted underline are affiliate links —
    <a href="/affiliate-disclosure" class="text-primary underline">learn more</a>.
  </p>

  {categories.map((cat) => (
    <section class="mb-10">
      <h2 class="text-xl font-bold mb-4 pb-2 border-b border-gray-200">{cat.name}</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {cat.tools.map((tool) => (
          <div class="border border-gray-200 rounded-xl p-5 bg-white hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-semibold">
                <AffiliateLink href={tool.url} name={tool.name} />
              </h3>
              {tool.free && (
                <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Free tier</span>
              )}
            </div>
            <p class="text-sm text-gray-600">{tool.description}</p>
          </div>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

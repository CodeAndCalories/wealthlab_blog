---
interface Props {
  heading?: string;
  subheading?: string;
  compact?: boolean;
}

const BEEHIIV_SUBSCRIBE_URL = "https://magic.beehiiv.com/v1/c93d1e86-34e5-4b93-bd94-fd2f3ae52d50";

const {
  heading = "Get smarter about money & AI",
  subheading = "Join 1,000+ readers getting weekly insights on personal finance and AI tools. Free, no spam.",
  compact = false,
} = Astro.props;
---

<section class:list={[
  "rounded-xl border border-primary/20 bg-primary/5",
  compact ? "p-4" : "p-6 md:p-8 text-center",
]}>
  {!compact && <h2 class="text-2xl font-bold mb-2">{heading}</h2>}
  {compact && <h3 class="text-lg font-semibold mb-1">{heading}</h3>}
  <p class:list={["text-gray-600", compact ? "text-sm mb-3" : "mb-6"]}>{subheading}</p>

  <div class:list={["flex justify-center", compact ? "" : "max-w-md mx-auto"]}>
    <a
      href={BEEHIIV_SUBSCRIBE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
    >
      Subscribe
    </a>
  </div>
</section>

---
import FormattedDate from "./FormattedDate.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, slug, tags = [], heroImage } = Astro.props;
---

<a href={`/blog/${slug}/`} class="group block">
  <article class="border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow bg-white">
    {heroImage && (
      <img src={heroImage} alt={title} class="w-full h-48 object-cover" />
    )}
    <div class="p-5">
      <div class="text-sm text-gray-500 mb-2">
        <FormattedDate date={pubDate} />
      </div>
      <h3 class="text-lg font-semibold group-hover:text-primary transition-colors mb-2">{title}</h3>
      <p class="text-gray-600 text-sm line-clamp-2">{description}</p>
      {tags.length > 0 && (
        <div class="flex gap-2 mt-3">
          {tags.map((tag) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </article>
</a>
